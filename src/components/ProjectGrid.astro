---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const allProjects = await getCollection('projects');

const getSizeClass = (size: string) => {
  switch (size) {
    case '2x2': return 'col-span-2 row-span-2 md:col-span-2 md:row-span-2';
    case '2x1': return 'col-span-2 row-span-1 md:col-span-2 md:row-span-1';
    case '1x1': 
    default:    return 'col-span-2 row-span-1 md:col-span-1 md:row-span-1';
  }
};
---

<div id="project-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[200px]">
  
  {allProjects.map((project: CollectionEntry<'projects'>) => (
    <a 
      href={`/projects/${project.id}`}
      class={`project-card relative block rounded-xl shadow-lg ${getSizeClass(project.data.size)} transition-all duration-300`}
    >
      <div transition:name={`img-${project.id}`} class="absolute inset-0 z-0 overflow-hidden rounded-xl">
        <img 
          src={project.data.image} 
          alt={project.data.title} 
          class="project-img w-full h-full object-cover transition-transform duration-700 ease-out" 
        />
      </div>
      
      <div class="project-overlay absolute inset-0 z-10 bg-black/60 opacity-0 transition-opacity duration-300 rounded-xl pointer-events-none"></div>
      
      <div class="absolute inset-0 z-20 flex flex-col justify-end p-6 text-white pointer-events-none">
        <h3 
          transition:name={`title-${project.id}`} 
          class="project-title text-2xl font-bold drop-shadow-xl transition-all duration-500"
        >
          {project.data.title}
        </h3>
        
        <div class="project-summary opacity-0 h-0 overflow-hidden transition-all duration-500 mt-2">
          <p class="text-sm mb-3">{project.data.summary}</p>
          
          <div class="flex flex-wrap gap-1 mb-4">
            {project.data.tags.map((tag: string) => (
              <span class="text-xs bg-white/20 px-2 py-1 rounded-full backdrop-blur-sm">
                {tag}
              </span>
            ))}
          </div>

          <span class="inline-block border border-white px-4 py-2 rounded text-sm bg-transparent">
            Click to read more
          </span>
        </div>
      </div>
    </a>
  ))}

</div>

<style>
  /* 1. The Accent Ring & Shadow */
  .project-card:hover {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    outline: 4px solid var(--accent);
    outline-offset: 2px;
  }
  
  /* 2. The Image Zoom */
  .project-card:hover .project-img {
    transform: scale(1.1);
  }
  
  /* 3. The Dark Fade-in */
  .project-card:hover .project-overlay {
    opacity: 1;
  }
  
  /* 4. The Title Glide */
  .project-card:hover .project-title {
    transform: translateY(-16px);
    filter: drop-shadow(0 0 0 transparent);
  }
  
  /* 5. The Summary Reveal */
  .project-card:hover .project-summary {
    opacity: 1;
    height: auto; /* Required to trigger the expansion */
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    
    // ==========================================
    // 1. INFINITE SCROLL LOGIC (Remains the same)
    // ==========================================
    const grid = document.getElementById('project-grid');
    if (!grid) return;

    const originalCards = Array.from(grid.children);
    let isAppending = false;

    const handleInfiniteScroll = () => {
      if (isAppending) return;

      const distanceToBottom = document.documentElement.scrollHeight - (window.scrollY + window.innerHeight);

      if (distanceToBottom < 600) {
        isAppending = true;

        originalCards.forEach(card => {
          const clone = card.cloneNode(true) as HTMLElement;
          
          clone.removeAttribute('data-astro-transition-scope');
          const elementsWithTransitions = clone.querySelectorAll('[data-astro-transition-scope]');
          elementsWithTransitions.forEach((node) => {
            const el = node as HTMLElement;
            el.removeAttribute('data-astro-transition-scope');
          });

          grid.appendChild(clone);
        });

        setTimeout(() => {
          isAppending = false;
        }, 100);
      }
    };

    window.addEventListener('scroll', handleInfiniteScroll);

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', handleInfiniteScroll);
    }, { once: true });


    // ==========================================
    // 2. NEW: THE DYNAMIC TRANSITION SWAPPER
    // ==========================================
    // We use 'mousedown' so our DOM changes happen a split-second before Astro triggers the page transition
    document.addEventListener('mousedown', (e) => {
      const card = (e.target as HTMLElement).closest('a.project-card');
      if (!card) return;

      const href = card.getAttribute('href');
      if (!href) return;
      
      const projectId = href.split('/').pop();
      
      // Find every copy of this project card on the page (Originals + Clones)
      const allMatchingCards = document.querySelectorAll(`a.project-card[href="${href}"]`);

      allMatchingCards.forEach(c => {
        // 1. Find the elements that hold the transition names
        const imgWrapper = c.querySelector('.project-img')?.parentElement as HTMLElement;
        const title = c.querySelector('.project-title') as HTMLElement;
        
        // 2. Nuke the transition names from all copies (This forcefully disconnects the original at the top of the page)
        if (imgWrapper) {
          imgWrapper.style.viewTransitionName = 'none';
          imgWrapper.removeAttribute('data-astro-transition-scope');
        }
        if (title) {
          title.style.viewTransitionName = 'none';
          title.removeAttribute('data-astro-transition-scope');
        }
      });

      // 3. Reactivate the transition names ONLY on the specific card under the user's mouse
      const activeImgWrapper = card.querySelector('.project-img')?.parentElement as HTMLElement;
      const activeTitle = card.querySelector('.project-title') as HTMLElement;

      // Astro uses exactly the string you provided in transition:name
      if (activeImgWrapper) activeImgWrapper.style.viewTransitionName = `img-${projectId}`;
      if (activeTitle) activeTitle.style.viewTransitionName = `title-${projectId}`;
    });

  });
</script>