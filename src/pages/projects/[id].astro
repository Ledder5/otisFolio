---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Generate a path for every markdown file in the collection
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

// 2. Extract the data and the compiled Markdown content
const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout>
  <aside 
    id="hero-sidebar" 
    transition:persist="sidebar"
    class="fixed top-0 left-0 z-50 md:w-1/3 h-screen bg-[var(--bg-color)] shadow-xl flex flex-col justify-center p-8 md:p-24 hidden md:flex"
  >
    </aside>

  <main class="w-full md:w-2/3 ml-auto min-h-screen relative bg-[var(--bg-color)]">
    
    <button 
      onclick="window.history.length > 1 ? history.back() : window.location.href = '/'" 
      class="fixed top-6 right-6 md:top-10 md:right-10 z-50 bg-black/50 hover:bg-black text-white rounded-full p-3 backdrop-blur-md transition-all duration-300 group cursor-pointer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transform group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="w-full h-[40vh] md:h-[60vh] relative overflow-hidden">
      
      <div transition:name={`img-${project.id}`} class="w-full h-full">
        <img
          src={project.data.image}
          alt={project.data.title}
          class="block w-full h-full object-cover"
        />
      </div>
      
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg-color)] to-transparent pointer-events-none"></div>
    </div>

    <article class="p-8 md:p-16 max-w-4xl mx-auto -mt-32 relative z-10">
      <h1 transition:name={`title-${project.id}`} class="text-4xl md:text-6xl font-bold mb-6">
        {project.data.title}
      </h1>
      
      <div class="flex flex-wrap gap-2 mb-12">
        {project.data.tags.map((tag: string) => (
          <span class="px-4 py-1 bg-gray-200 dark:bg-gray-800 rounded-full text-sm font-medium">{tag}</span>
        ))}
      </div>

      <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-accent">
        <Content />
      </div>
    </article>
  </main>
</Layout>