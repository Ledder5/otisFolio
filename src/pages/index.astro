---
import Layout from '../layouts/Layout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
---

<Layout>
  <aside 
    id="hero-sidebar" 
    class="fixed md:relative top-0 left-0 z-50 w-full h-screen bg-[var(--bg-color)] transition-all duration-700 ease-in-out md:w-full flex flex-col justify-center p-8 md:p-24"
  >
    <div class="animate-fade-in">
      <h1 class="text-5xl font-bold mb-4">Hi, I'm [Your Name]</h1>
      
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-2">Skills</h2>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-gray-200 dark:bg-gray-800 rounded-full cursor-pointer hover:bg-accent transition-colors">Astro</span>
          <span class="px-3 py-1 bg-gray-200 dark:bg-gray-800 rounded-full cursor-pointer hover:bg-accent transition-colors">Tailwind</span>
        </div>
      </div>

      <nav class="space-y-4">
        <a href="/experience" class="block text-lg hover:text-accent transition-colors">Experience & Qualifications</a>
        <a href="/about" class="block text-lg hover:text-accent transition-colors">About Me</a>
        <a href="/resume.pdf" target="_blank" class="block text-lg hover:text-accent transition-colors">Resume</a>
      </nav>

      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 md:left-24 md:translate-x-0 animate-bounce">
        <p class="text-sm text-gray-500">Scroll to explore my work ↓</p>
      </div>
    </div>
  </aside>

  <main 
    id="projects-area" 
    class="w-full md:w-2/3 ml-auto opacity-0 translate-y-20 transition-all duration-1000 ease-out pt-screen md:pt-0"
  >
    <div class="p-4 md:p-8">
      <ProjectGrid />
    </div>
  </main>
</Layout>

<script>
  // This script handles the funnel scroll effect
  window.addEventListener('scroll', () => {
    const sidebar = document.getElementById('hero-sidebar');
    const projects = document.getElementById('projects-area');

	// GUARD CLAUSE: If these elements aren't on the page, stop here.
    if (!sidebar || !projects) return;
    
    if (window.scrollY > 50) {
      // User scrolled: Shrink sidebar to left, fade in projects
      sidebar.classList.remove('md:w-full');
      sidebar.classList.add('md:w-1/3', 'shadow-xl');
      
      projects.classList.remove('opacity-0', 'translate-y-20');
      projects.classList.add('opacity-100', 'translate-y-0');
    } else {
      // User at top: Full screen landing
      sidebar.classList.add('md:w-full');
      sidebar.classList.remove('md:w-1/3', 'shadow-xl');
      
      projects.classList.add('opacity-0', 'translate-y-20');
      projects.classList.remove('opacity-100', 'translate-y-0');
    }
  });
</script>
